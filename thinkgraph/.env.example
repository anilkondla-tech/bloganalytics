# ============================================================================
# ThinkGraph AI — environment configuration
# Copy this file to `.env.local` for local dev, and set the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# NEVER commit real values. `.env.local` is git-ignored.
# ============================================================================

# --- Which sites are available in the app (comma-separated keys) ---
THINKGRAPH_SITES=tech360d,techinfobeez,fashionsgalaxy,techsprohub
THINKGRAPH_DEFAULT_SITE=techsprohub

# --- Per-site WordPress (MySQL) connection ---
# Repeat this block for each key listed in THINKGRAPH_SITES (uppercased).
SITE_TECH360D_LABEL=Tech360d
SITE_TECH360D_URL=https://tech360d.com
SITE_TECH360D_HOST=your-db-host.example.com
SITE_TECH360D_PORT=3306
SITE_TECH360D_USER=your_db_user
SITE_TECH360D_PASSWORD=your_db_password
SITE_TECH360D_DATABASE=your_db_name
SITE_TECH360D_PREFIX=wp_

# SITE_TECHINFOBEEZ_...   (same shape)
# SITE_FASHIONSGALAXY_... (same shape)
# SITE_TECHSPROHUB_...    (same shape)

# --- AI (optional). Without a key, the app still works with deterministic insights. ---
ANTHROPIC_API_KEY=
THINKGRAPH_AI_MODEL=claude-opus-4-8

# --- Behaviour ---
# When true, the app skips the DB entirely and renders the bundled demo dataset.
# Useful for a public Vercel preview when the DB host blocks Vercel's IPs.
THINKGRAPH_DEMO_MODE=false
